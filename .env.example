# Copy to .env and fill in. Never commit .env.

# Claude / Anthropic
ANTHROPIC_API_KEY=

# Polymarket
# API creds are auto-derived from your private key on first run; leave blank.
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_PASSPHRASE=
# Required for LIVE trading:
POLYMARKET_WALLET_PRIVATE_KEY=
POLYMARKET_FUNDER=            # address holding your USDC (proxy/funder)
POLYMARKET_SIGNATURE_TYPE=1   # 1 = email/Magic wallet, 0 = browser EOA, 2 = proxy
POLYMARKET_CHAIN_ID=137       # Polygon

# Bot config
MAX_TRADES_PER_DAY=10
AGREEMENT_WINDOW_MINUTES=30
MIN_WALLETS_AGREE=3
TAKE_PROFIT_PCT=0.15
STAKE_USD=20
START_BANKROLL=200
POLL_SECONDS=60
DRY_RUN=true
