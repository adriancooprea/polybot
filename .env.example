# Copy to .env and fill in. Never commit .env.

# Claude / Anthropic (optional — without it, trades fire on wallet consensus alone)
ANTHROPIC_API_KEY=
# Vote model. Default claude-opus-4-7 (~$18/mo). claude-haiku-4-5 ~ $1/mo.
CLAUDE_MODEL=claude-opus-4-7

# Polymarket
# API creds are auto-derived from your private key on first run; leave blank.
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_PASSPHRASE=
# Required for LIVE trading:
POLYMARKET_WALLET_PRIVATE_KEY=
POLYMARKET_FUNDER=            # deposit wallet address (holds your USDC) — NOT the EOA
# Signature type: 0=EOA, 1=POLY_PROXY (old email), 2=GNOSIS_SAFE,
# 3=POLY_1271 (new EIP-7702 deposit wallets — current Polymarket default).
# NOTE: as of 2026-05, the py-clob-client-v2 SDK cannot post orders for
# POLY_1271 deposit wallets (upstream L1-auth bug, issues #65/#70/#71).
# Reads (balance/positions) work; live order submission is blocked until fixed.
POLYMARKET_SIGNATURE_TYPE=3
POLYMARKET_CHAIN_ID=137       # Polygon

# Bot config
MAX_TRADES_PER_DAY=10
AGREEMENT_WINDOW_MINUTES=30
MIN_WALLETS_AGREE=3
TAKE_PROFIT_PCT=0.15
STAKE_USD=20
START_BANKROLL=200
POLL_SECONDS=60
DRY_RUN=true
